⚙️ 4. RUNTIME LOOP

core/aegis_kernel.py

class AegisKernel:

    def __init__(self, compiler):
        self.compiler = compiler

    def run(self, program):

        parsed = self.compiler.parse(program)

        if not self.compiler.validate(parsed):
            return "REJECTED"

        events = self.compiler.execute(parsed)

        return {
            "status": "COMMITTED",
            "events": events
        }


