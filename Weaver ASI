llm/dwl_compiler.py

from types.dcts import judge

class DWLCompiler:

    def __init__(self, llm, control_plane, event_store, type_checker):
        self.llm = llm
        self.cp = control_plane
        self.store = event_store
        self.tc = type_checker

    def parse(self, program):
        return self.llm.generate(f"Parse DWL:\n{program}")

    def type_check(self, plan):
        return self.tc.check(plan)

    def validate(self, plan):
        if not self.type_check(plan):
            return False

        for step in plan["plan"]:
            decision = self.cp.evaluate(step)
            if decision != "EXECUTE":
                return False

        return True

    def execute(self, plan):
        events = []

        for step in plan["plan"]:
            event = {
                "type": "DW_EVENT",
                "action": step["action"],
                "target": step.get("target")
            }

            self.store.append(event)
            events.append(event)

        return events


