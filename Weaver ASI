🧠 3. TYPE CHECKER (DCTS CORE)

llm/type_checker.py

class TypeChecker:

    def check(self, plan):

        prev_type = "Plan"

        for step in plan["plan"]:

            current_type = self.infer(step)

            if not self.valid_transition(prev_type, current_type):
                return False

            prev_type = current_type

        return True

    def infer(self, step):

        if step["action"] == "CALL":
            return "Observation"

        if step["action"] == "EMIT":
            return "Event"

        if step["action"] == "PLAN":
            return "Plan"

        return "Unknown"

    def valid_transition(self, a, b):

        rules = {
            "Plan": ["Observation", "Event"],
            "Observation": ["Event"],
            "Event": ["State"]
        }

        return b in rules.get(a, [])


