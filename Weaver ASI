        self.output_type = output_type

class Plan:
    def __init__(self, steps):
        self.steps = steps

class Observation:
    pass

class Memory:
    pass

# -------------------------
# TYPE JUDGMENT SYSTEM
# -------------------------

def judge(expression: Any) -> str:
    if isinstance(expression, Event):
        return "Event"
    if isinstance(expression, Tool):
        return "Tool"
    if isinstance(expression, Plan):
        return "Plan"
    if isinstance(expression, Observation):
        return "Observation"
    if isinstance(expression, State):
        return "State"
    return "Unknown"


